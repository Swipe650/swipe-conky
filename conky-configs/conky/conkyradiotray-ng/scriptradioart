On_radioparadise()
#Get what's on radio paradise and download cover artist
{
        # Fetch JSON data from new API and save local copy
        curl -o ~/.config/radiotray-ng/bookmark_icons/now.json "https://api.radioparadise.com/api/now_playing?"
        
        # Extract cover_small URL from JSON
        chk_art=$(jq -r '.cover_small' ~/.config/radiotray-ng/bookmark_icons/now.json 2>/dev/null)
        # Store previous coverart for comparison (if exists)
        if [ -f ~/.config/radiotray-ng/bookmark_icons/prev_coverart.txt ]; then
            prev_art=$(cat ~/.config/radiotray-ng/bookmark_icons/prev_coverart.txt)
        else
            prev_art=""
        fi
            
        # Check if the coverart urls match and, if not, get new coverart and resize to 110 width
        if [ "$prev_art" != "$chk_art" ] && [ -n "$chk_art" ] && [ "$chk_art" != "null" ]; then 
            curl -o ~/.config/radiotray-ng/bookmark_icons/rp_art "$chk_art"
            magick ~/.config/radiotray-ng/bookmark_icons/rp_art -resize 110 ~/.config/radiotray-ng/bookmark_icons/icon
            echo "$chk_art" > ~/.config/radiotray-ng/bookmark_icons/prev_coverart.txt
        fi
        
        # Extract artist and song title from JSON
        rpartist=$(jq -r '.artist' ~/.config/radiotray-ng/bookmark_icons/now.json 2>/dev/null | sed 's/amp;//g')
        rpsongtitle=$(jq -r '.title' ~/.config/radiotray-ng/bookmark_icons/now.json 2>/dev/null | sed 's/amp;//g')
        
        # echo artist and song to conky file
        echo "$rpartist" > ~/.conky/conkyradiotray-ng/onair.txt
        truncate --size -1 ~/.conky/conkyradiotray-ng/onair.txt
        echo " - " >> ~/.conky/conkyradiotray-ng/onair.txt
        truncate --size -1 ~/.conky/conkyradiotray-ng/onair.txt
        echo "$rpsongtitle" >> ~/.conky/conkyradiotray-ng/onair.txt
}

