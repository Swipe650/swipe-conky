        On_Talksport2
;;
    "$fivelive" )
        magick ~/.config/radiotray-ng/bookmark_icons/5live -resize 110 ~/.config/radiotray-ng/bookmark_icons/icon
       
;;
    "$radiostoke" )
        magick ~/.config/radiotray-ng/bookmark_icons/radiostoke -resize 110 ~/.config/radiotray-ng/bookmark_icons/icon
        
;;
    "$bloomr" )
        magick ~/.config/radiotray-ng/bookmark_icons/br -resize 110 ~/.config/radiotray-ng/bookmark_icons/icon    
;;
    "$radio_paradise" )
        On_radioparadise
;;
    "$radio_paradise_rock" )
        On_radioparadise_rock
;;
    "$radio_paradise_mellow" )
        On_radioparadise_mellow
;;
    #If status = 'not playing' don't do anything
    "$not_playing" )
;;
    #If any other case get albumart using miniatureGoogleImage
    *)
        # Set paths
        ICON_PATH="$HOME/.config/radiotray-ng/bookmark_icons/icon"
        HASH_FILE="/tmp/radiotray_hash"
        ARTIST_TITLE_FILE="$HOME/.conky/conkyradiotray-ng/artist_title.txt"
        
        # Generate hash from current artist and song
        current_hash=$(echo "$ar$so" | md5sum | cut -d' ' -f1)
        saved_hash=""
        
        # Read saved hash if file exists
        if [ -f "$HASH_FILE" ]; then
            saved_hash=$(cat "$HASH_FILE")
        fi
        
        # Check if track has changed
        if [ "$saved_hash" != "$current_hash" ]; then
            # Track changed - need to get new album art
            if [ -n "$ar" ] && [ -n "$so" ] && [ "$ar" != "null" ] && [ "$so" != "null" ]; then
                
                # Save artist and title to file
                echo "$ar - $so" | fold -s -w80 > "$ARTIST_TITLE_FILE"
                
                # Prepare search string
                title_search=$(echo "$ar - $so" | sed 's/ /+/g' | sed 's/&/%26/g' | sed 's/#/%23/g' | sed 's/:/%3A/g' | sed 's/;/%3B/g' | sed 's/,/%2C/g' | sed 's/\[/%5B/g' | sed 's/\]/%5D/g')
                
                # Get image URL from Google
                linkMiniature=$(wget -U 'Googlebot-Image/1.0' -qO - "www.google.co.uk/search?q=$title_search\&tbm=isch" | awk -v RS='[[:blank:]]' '/^src=/' | awk 'NR==2' | cut -c6- | sed 's/.\{11\}$//')
                
                # Download and process image if URL is valid
                if [ -n "$linkMiniature" ] && [ "$linkMiniature" != "http://" ] && [ "$linkMiniature" != "https://" ]; then
                    wget -O /tmp/miniatureGoogleImage "$linkMiniature" 2>/dev/null
                    
                    # Verify download succeeded (file exists and has content)
                    if [ -f /tmp/miniatureGoogleImage ] && [ -s /tmp/miniatureGoogleImage ]; then
                        # Check if it's a valid image (optional but recommended)
                        if file /tmp/miniatureGoogleImage | grep -q "image"; then
                            magick /tmp/miniatureGoogleImage -resize 110 "$ICON_PATH"
                            # Save hash ONLY after successful download
                            echo "$current_hash" > "$HASH_FILE"
                        fi
                    fi
                fi
            fi
        fi
        # If hash matches, album art is already correct - do nothing
;;
esac

# Show artist and title info or "No Info"
if [ "$lbc_uk" = "$st" ] || [ "$lbc_news" = "$st" ]  || [ "$gb_news" = "$st" ] || [ "$lbc_london" = "$st" ] || [ "$radio_paradise" = "$st" ]  || [ "$radio_paradise_rock" = "$st" ] || [ "$radio_paradise_mellow" = "$st" ] || [ "$talksport" = "$st" ] || [ "$times_radio" = "$st" ] || [ "$talkradio" = "$st" ]; #|| [ "$talksport2" = "$st" ] 
